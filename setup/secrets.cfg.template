# secrets.cfg — Copy to secrets.cfg and fill in real values
# cp setup/secrets.cfg.template setup/secrets.cfg

# Keycloak admin credentials
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_REALM=multi-agent

# Optionnel — dashboard derrière un reverse proxy public (TLS).
# Vide = issuer interne (KEYCLOAK_URL). Sinon (ex. https://mon-domaine.example.com)
# Keycloak émettra cet issuer dans les tokens (claim "iss") et le backend
# l'exigera ; KEYCLOAK_URL reste l'URL interne (JWKS + proxy /auth).
# Relancer Keycloak après modification (docker rm ma-keycloak + infra.sh start).
KEYCLOAK_PUBLIC_URL=
# Override explicite si l'issuer ne suit pas <url>/realms/<realm> :
#KEYCLOAK_ISSUER=https://mon-domaine.example.com/realms/multi-agent

# Inter-service auth token (generated randomly, shared between services)
HEALTH_TOKEN=changeme

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
