# Drop-in de référence :
#   sudo systemctl edit multiagent-dashboard.service
# Copier ce bloc puis adapter le chemin si le dépôt n'est pas dans %h/multi-agent.
[Service]
EnvironmentFile=%h/multi-agent/setup/secrets.cfg
# PATH stable : placer dans %h/.local/bin des liens vers les binaires actifs
# node/claude/codex (voir patch/HOW_TO_UPGRADE.md). Ne jamais figer ici une
# version NVM propre à une machine.
Environment=PATH=%h/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/snap/bin
ReadWritePaths=%h/multi-agent/logs
ReadWritePaths=%h/multi-agent/uploads
ReadWritePaths=%h/multi-agent/crontab
ReadWritePaths=%h/multi-agent/keepalive
ReadWritePaths=%h/multi-agent/prompts
