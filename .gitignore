# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
.venv/

# Logs
logs/*
!logs/.gitkeep
*.log

# Sessions (runtime)
sessions/*
!sessions/.gitkeep

# State files (runtime)
pool-requests/state/*
!pool-requests/state/.gitkeep

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Project specific (user code)
project/*
!project/.gitkeep
!project/README.md

# Redis
dump.rdb

# Node / Frontend build
node_modules/
web/frontend/dist/

# Temp
*.tmp
*.temp
.cache/

# Config locale (créé par 900)
project-config.md

# Config panel locale (overrides agent panel types)
web/panel-config.json

# Checksum local (généré par patch/sync-to-git.sh)
file.md5

# Pipeline output (project-specific)
pipeline/

# Project-specific test subdirs
tests/messaging/
tests/mail/

# Pool requests runtime (garder la structure vide)
pool-requests/pending/*
pool-requests/assigned/*
pool-requests/done/*
pool-requests/specs/*
pool-requests/tests/*
!pool-requests/*/.gitkeep
# Claude profiles (API credentials)
login/*
!login/.gitkeep

web/backend/.pytest_cache/
web/backend/venv/

# Safe-delete archive
removed/
